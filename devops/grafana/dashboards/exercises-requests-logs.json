            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "_time_pad",
            "binary": {
              "left": "_epoch_ms",
              "operator": "*",
              "right": "1000"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "_order_pad",
            "binary": {
              "left": "service_order",
              "operator": "*",
              "right": "100"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "_base",
            "binary": {
              "left": "_time_pad",
              "operator": "+",
              "right": "_order_pad"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "sort_key",
            "binary": {
              "left": "_base",
              "operator": "+",
              "right": "log_seq"
            },
            "mode": "binary",
            "replaceFields": false
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": false,
                "field": "sort_key"
              }
            ]
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "config": {
                  "id": "regex",
                  "options": {
                    "value": ".+"
                  }
                },
                "fieldName": "correlate_id"
              }
            ],
            "match": "all",
            "type": "include"
          }
        },
        {
