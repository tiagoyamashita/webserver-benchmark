{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "elasticsearch",
        "uid": "elasticsearch"
      },
      "description": "HTTP access/controller lines and Postgres SQL execute logs. Probe traffic (health, metrics, GET /) is hidden.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "path"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "path_rust"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "sql"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "DELETE": {
                        "color": "red",
                        "index": 0
                      },
                      "INSERT": {
                        "color": "green",
                        "index": 1
                      },
                      "SELECT": {
                        "color": "blue",
                        "index": 2
                      },
                      "UPDATE": {
                        "color": "yellow",
                        "index": 3
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "message"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 480
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto",
                  "wrapText": true
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status_rust"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 24,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "@timestamp"
          }
        ]
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "bucketAggs": [],
          "datasource": {
            "type": "elasticsearch",
            "uid": "elasticsearch"
          },
          "metrics": [
            {
              "id": "1",
              "settings": {
                "size": "300"
              },
              "type": "raw_data"
            }
          ],
          "query": "((service:\"exercises-java\" OR service:\"exercises-rust\" OR service:\"exercises-python\" OR service:\"exercises-react-node\") AND (_exists_:path OR _exists_:fields.path OR _exists_:controller OR _exists_:request_id OR _exists_:fields.request_id OR _exists_:status OR _exists_:fields.status) AND NOT (path:\"/health\" OR path:\"/api/health\" OR path:\"/metrics\" OR path:\"/actuator/prometheus\" OR path:\"/api/observability/health\" OR fields.path:\"/health\" OR fields.path:\"/api/health\" OR fields.path:\"/metrics\" OR fields.path:\"/actuator/prometheus\" OR fields.path:\"/api/observability/health\" OR controller:health OR fields.controller:health OR ((path:\"/\" OR fields.path:\"/\") AND (method:GET OR fields.method:GET)))) OR (service:\"exercises-postgres\" AND (message:*execute* OR message:statement*) AND NOT message:duration* AND NOT message:*set_config* AND NOT message:*SELECT 1* AND NOT message:*connection* AND NOT message:*disconnection*)",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ],
      "title": "Request & SQL logs",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "regexp",
            "regexp": "^(?<origin>exercises-[^;]+);req=(?<request_id_pg>.+)$",
            "source": "application_name"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "_id": true,
              "_index": true,
              "_source": true,
              "_type": true,
              "agent": true,
              "backend_type": true,
              "dbname": true,
              "ecs": true,
              "error_severity": true,
              "event": true,
              "highlight": true,
              "host": true,
              "input": true,
              "level": true,
              "line_num": true,
              "log": true,
              "logger_name": true,
              "pid": true,
              "query_id": true,
              "remote_host": true,
              "remote_port": true,
              "session_start": true,
              "sort": true,
              "springAppName": true,
              "tags": true,
              "txid": true,
              "user": true,
              "vxid": true
            },
            "indexByName": {
              "@timestamp": 0,
              "service": 1,
              "path": 2,
              "fields.path": 3,
              "method": 4,
              "fields.method": 5,
              "status": 6,
              "fields.status": 7,
              "ps": 8,
              "session_id": 9,
              "request_id": 10,
              "fields.request_id": 11,
              "request_id_pg": 12,
              "origin": 13,
              "application_name": 14,
              "controller": 15,
              "detail": 16,
              "ms": 17,
              "message": 18
            },
            "renameByName": {
              "fields.method": "method_rust",
              "fields.path": "path_rust",
              "fields.request_id": "request_id_rust",
              "fields.status": "status_rust",
              "ps": "sql"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "exercises",
    "elasticsearch",
    "logs",
    "http",
    "postgres"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Exercises HTTP requests & SQL logs",
  "uid": "exercises-requests-logs",
  "version": 72
}
