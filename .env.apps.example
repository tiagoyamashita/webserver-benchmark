# Copy to .env.apps (optional overrides for docker-compose.apps.yml / docker-compose.dev.yml).
#   copy .env.apps.example .env.apps   (Windows)
#   cp .env.apps.example .env.apps     (Linux/macOS)
#
# JSON logs -> apps/*/logs/demo-app.json.log -> Filebeat -> Elasticsearch (Grafana dashboards).

EXERCISES_OBSERVABILITY=1
LOG_PATH=logs

# Java (Spring profile when running outside Compose or overriding dev)
SPRING_PROFILES_ACTIVE=postgres,observability

# Redis (Compose service name; host-side clients use 127.0.0.1:6379 — see apps/redis/README.md)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Kafka (Compose service name; use 127.0.0.1:9092 only with host-side clients — see apps/kafka/README.md)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Rust: topic admin on startup (mirrors Java app.kafka.create-user-* / spring.kafka.admin.fail-fast)
KAFKA_CREATE_USER_TOPIC=create-user
KAFKA_CREATE_USER_CONSUMER_GROUP=exercises-create-user
KAFKA_CREATE_USER_PARTITIONS=1
KAFKA_CREATE_USER_REPLICAS=1
KAFKA_ADMIN_FAIL_FAST=true
# Python: create-item consumer (Java publishes from dashboard)
KAFKA_CREATE_ITEM_TOPIC=create-item
KAFKA_CREATE_ITEM_CONSUMER_GROUP=exercises-create-item-python
