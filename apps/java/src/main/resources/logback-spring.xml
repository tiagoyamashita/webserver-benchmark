<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

  <springProperty scope="context" name="springAppName" source="spring.application.name" defaultValue="exercises-java"/>

  <springProfile name="observability">
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOG_PATH:-logs}/demo-app.json.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOG_PATH:-logs}/demo-app.json.log.%d{yyyy-MM-dd}.gz</fileNamePattern>
        <maxHistory>14</maxHistory>
      </rollingPolicy>
      <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
        <customFields>{"service":"${springAppName}"}</customFields>
        <providers>
          <timestamp>
            <fieldName>timestamp</fieldName>
          </timestamp>
          <version/>
          <logLevel/>
          <logLevelValue/>
          <loggerName/>
          <threadName/>
          <message/>
          <logstashMarkers/>
          <arguments/>
          <stackTrace/>
          <provider class="com.example.demo.observability.ObservabilityJsonProvider"/>
        </providers>
      </encoder>
    </appender>
  </springProfile>

  <springProfile name="observability">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="JSON_FILE"/>
    </root>
  </springProfile>

  <springProfile name="!observability">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>
</configuration>
