# syntax=docker/dockerfile:1
# Dev image: mount ./rust at /app and use docker-compose.dev.yml (cargo-watch reload).
FROM rust:1.86-bookworm
WORKDIR /app
RUN cargo install cargo-watch --locked
ENV WEBSERVER_BENCHMARK_WEB_HOST=0.0.0.0
ENV WEBSERVER_BENCHMARK_WEB_PORT=8082
ENV WEBSERVER_BENCHMARK_RUST_ROOT=/app
ENV WEBSERVER_BENCHMARK_OBSERVABILITY=1
ENV LOG_PATH=/app/logs
EXPOSE 8082
# --poll: poll for file changes (bind mounts on Windows/Podman often miss inotify).
CMD ["cargo", "watch", "--poll", "-w", "src", "-w", "templates", "-x", "run --bin exercises-web"]
