# Server port (Compose publishes 5174:5174).
#PORT=5174

# Outbound probe targets — Compose sets service DNS names; local defaults use localhost.
#PROBE_JAVA_URL=http://java:8080
#PROBE_RUST_URL=http://rust:8082
#PROBE_PYTHON_URL=http://python:5000
#PROBE_PROMETHEUS_URL=http://prometheus:9090
#PROBE_GRAFANA_URL=http://grafana:3000
#PROBE_ELASTICSEARCH_URL=http://elasticsearch:9200
#PROBE_KIBANA_URL=http://kibana:5601
